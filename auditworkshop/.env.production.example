# Vorlage für /etc/auditworkshop/env auf dem CCX23.
# Wird per `lifecycle/bootstrap.sh` an den Zielort kopiert.
# Werte stammen aus dem Cockpit-Tracker-Tresor:
#   POST /api/v1/secrets/{id}/reveal mit purpose und task_context_id.
# Datei am Ziel mit Mode 0600 und Eigentümer root.
#
# Diese Datei darf NIE mit echten Werten committet werden.

# ── Datenbank (shared Postgres auf CCX23, Schema workshop) ──
DATABASE_URL=postgresql://workshop_app:CHANGE_ME@cockpit-postgres:5432/cockpit?options=-c%20search_path%3Dworkshop

# ── LLM-Routing ────────────────────────────────────────────
# Phase A: direktes Tailscale-Routing zur NUC, solange llm-router
# (Workstream E) noch nicht steht.
OLLAMA_URL=http://nuc.tailnet:11434
EGPU_GATEWAY_URL=http://nuc.tailnet:7842

# Phase B: Umstellung auf llm-router-Container im selben Docker-Netz
# auf CCX23, sobald Workstream E grün ist.
# OLLAMA_URL=http://llm-router:7842/v1
# EGPU_GATEWAY_URL=http://llm-router:7842

LLM_BACKEND=egpu-manager
EGPU_GATEWAY_APP_ID=auditworkshop
EGPU_WORKLOAD_TYPE=llm
EMBEDDING_BACKEND=gateway
EMBEDDING_GATEWAY_URL=${EGPU_GATEWAY_URL}
EMBEDDING_GATEWAY_APP_ID=auditworkshop
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
MODEL_NAME=qwen3:14b

# ── Workshop-Constraints ───────────────────────────────────
WORKSHOP_ADMIN=true
ALLOW_REMOTE_GEOCODING=false
ALLOW_REMOTE_TILES=true

# ── Cockpit-konformes Logging ──────────────────────────────
WORKSHOP_ENVIRONMENT=production
WORKSHOP_SERVICE_NAME=auditworkshop-backend
LOG_FORMAT=json
LOG_LEVEL=INFO

# ── Image-Tag (per Deploy-Workflow gesetzt) ────────────────
# IMAGE_TAG=sha-abc1234
